{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>

      <div id="service-charge-loading" data-testid="service-charge-loading">
        <p class="govuk-body">{{ labels.loadingMessage }}</p>
      </div>

      <div id="service-charge-content" data-testid="service-charge-content" hidden>
        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ labels.organisationLabel }}</dt>
            <dd class="govuk-summary-list__value" data-testid="service-charge-organisation"></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ labels.complianceLabel }}</dt>
            <dd class="govuk-summary-list__value" data-testid="service-charge-period"></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ labels.feeLabel }}</dt>
            <dd class="govuk-summary-list__value" data-testid="service-charge-fee"></dd>
          </div>
        </dl>

        <p class="govuk-body" data-testid="service-charge-note"></p>

        {{ govukButton({
          text: labels.payAction,
          attributes: { "data-testid": "service-charge-pay", "id": "service-charge-pay" }
        }) }}
        <p class="govuk-body">
          <a class="govuk-link" href="{{ dashboardUrl }}" data-testid="service-charge-cancel">{{ labels.cancelAction }}</a>
        </p>
      </div>

      <div id="service-charge-processing" data-testid="service-charge-processing" hidden>
        <p class="govuk-body" data-testid="service-charge-processing-message">{{ labels.processing }}</p>
      </div>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('serviceCharge.js') }}"></script>
{% endblock %}

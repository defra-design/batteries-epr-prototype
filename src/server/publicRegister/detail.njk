{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body">
        <a class="govuk-link" href="{{ searchUrl }}" data-testid="back-to-search">Back to search</a>
      </p>

      <h1 class="govuk-heading-l">{{ heading }}</h1>

      <div id="producer-detail" data-testid="producer-detail">
        <p class="govuk-body" data-testid="producer-detail-loading">Loading producer record…</p>
      </div>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{"bprn":"{{ bprn }}","searchUrl":"{{ searchUrl }}"}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('publicRegisterDetail.js') }}"></script>
{% endblock %}

{% extends 'layouts/page.njk' %}

{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="obligation-heading">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>
      <p class="govuk-body govuk-!-margin-bottom-2">
        <strong>Compliance period:</strong> <span data-testid="obligation-period">{{ compliancePeriodYear }}</span>
      </p>

      <h2 class="govuk-heading-m" data-testid="obligation-certificate-heading">{{ labels.certificate.heading }}</h2>
      <p class="govuk-body">{{ labels.certificate.intro }}</p>
      <dl class="govuk-summary-list" data-testid="obligation-certificate-summary">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.certificate.calculatedAtLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="obligation-certificate-calculated-at"></dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.certificate.ruleVersionLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="obligation-certificate-rule-version"></dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.certificate.configLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="obligation-certificate-config"></dd>
        </div>
      </dl>

      <h3 class="govuk-heading-s">{{ labels.certificate.targetsHeading }}</h3>
      <ul class="govuk-list govuk-list--bullet" data-testid="obligation-certificate-targets"></ul>
      <p class="govuk-body" data-testid="obligation-certificate-caveat">{{ labels.certificate.caveat }}</p>

      <table class="govuk-table" data-testid="obligation-table">
        <caption class="govuk-table__caption govuk-table__caption--m">{{ labels.tableCaption }}</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ labels.columns.category }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.placed }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.target }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.obligation }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.accepted }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.outstanding }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body" data-testid="obligation-body"></tbody>
        <tfoot data-testid="obligation-foot">
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header">{{ labels.totalsLabel }}</th>
            <td class="govuk-table__cell govuk-table__cell--numeric" data-testid="obligation-total-placed"></td>
            <td class="govuk-table__cell"></td>
            <td class="govuk-table__cell govuk-table__cell--numeric" data-testid="obligation-total-obligation"></td>
            <td class="govuk-table__cell govuk-table__cell--numeric" data-testid="obligation-total-accepted"></td>
            <td class="govuk-table__cell govuk-table__cell--numeric" data-testid="obligation-total-outstanding"></td>
          </tr>
        </tfoot>
      </table>

      <h2 class="govuk-heading-m" data-testid="obligation-calc-heading">{{ labels.calcHeading }}</h2>
      <p class="govuk-body">{{ labels.calcIntro }}</p>

      {% set formulaTypes = [
        {
          key: 'collection',
          heading: labels.formula.collectionHeading,
          targetTerm: labels.formula.collectionTargetTerm,
          resultLabel: labels.formula.collectionResultLabel
        },
        {
          key: 'recycling',
          heading: labels.formula.recyclingHeading,
          targetTerm: labels.formula.recyclingTargetTerm,
          resultLabel: labels.formula.recyclingResultLabel
        }
      ] %}

      {% for category, categoryLabel in labels.categories %}
        <details class="govuk-details" data-testid="obligation-calc-{{ category }}">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">{{ categoryLabel }}</span>
          </summary>
          <div class="govuk-details__text">
            {% for type in formulaTypes %}
              <h3 class="govuk-heading-s">{{ type.heading }}</h3>
              <p class="govuk-body"><strong>{{ labels.formulaEquation }}</strong></p>
              <ul class="govuk-list govuk-list--bullet">
                <li>
                  <strong>X</strong> is
                  <span data-testid="obligation-calc-{{ category }}-{{ type.key }}-placed">0.000</span>
                  {{ labels.formula.tonnesUnit }} ({{ labels.formula.placedTerm }})
                </li>
                <li>
                  <strong>Y</strong> is
                  <span data-testid="obligation-calc-{{ category }}-{{ type.key }}-target">0</span>%
                  ({{ type.targetTerm }})
                </li>
              </ul>
              <p class="govuk-body">
                {{ type.resultLabel }}<br>
                <strong>
                  <span data-testid="obligation-calc-{{ category }}-{{ type.key }}-placed">0.000</span>
                  {{ labels.formula.tonnesUnit }} ×
                  <span data-testid="obligation-calc-{{ category }}-{{ type.key }}-target">0</span>% =
                  <span data-testid="obligation-calc-{{ category }}-{{ type.key }}-obligation">0.000</span>
                  {{ labels.formula.tonnesUnit }}
                </strong>
              </p>
            {% endfor %}
          </div>
        </details>
      {% endfor %}

      {{ govukWarningText({
        text: labels.warningText,
        iconFallbackText: "Warning",
        attributes: { "data-testid": "obligation-calc-warning" }
      }) }}

      <p class="govuk-body">
        <a class="govuk-link" href="{{ dashboardUrl }}" data-testid="obligation-back-link">{{ labels.backToDashboardAction }}</a>
      </p>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('complianceSchemeObligation.js') }}"></script>
{% endblock %}

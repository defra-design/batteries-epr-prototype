{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="evidence-heading">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>
      <p class="govuk-body govuk-!-margin-bottom-2">
        <strong>Compliance period:</strong> <span data-testid="evidence-period">{{ compliancePeriodYear }}</span>
      </p>

      <div class="govuk-button-group">
        {{ govukButton({
          text: labels.issueAction,
          href: pagePayload.urls.issue,
          attributes: { "data-testid": "evidence-issue-link" }
        }) }}
        {{ govukButton({
          text: labels.availabilityAction,
          href: pagePayload.urls.availability,
          classes: "govuk-button--secondary",
          attributes: { "data-testid": "evidence-availability-link" }
        }) }}
      </div>

      <table class="govuk-table" data-testid="evidence-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ labels.columns.recipient }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.category }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.tonnes }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.status }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.transfer }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.actions }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body" data-testid="evidence-body"></tbody>
      </table>
      <p class="govuk-body" data-testid="evidence-empty" hidden>{{ labels.emptyMessage }}</p>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ pagePayload.urls.dashboard }}" data-testid="evidence-back-link">{{ labels.backToDashboardAction }}</a>
      </p>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('complianceSchemeEvidence.js') }}"></script>
{% endblock %}

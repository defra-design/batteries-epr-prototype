{% extends 'complianceSchemeQuarterly/_layout.njk' %}

{% block stepBody %}
  <form method="post" action="{{ action }}" novalidate data-testid="quarterly-form">
    {{ govukCheckboxes({
      idPrefix: "declarationAccepted",
      name: "declarationAccepted",
      errorMessage: { text: errors.declarationAccepted } if errors.declarationAccepted,
      items: [
        {
          value: "yes",
          text: labels.declarationLabel,
          checked: formValues.declarationAccepted == "yes"
        }
      ],
      attributes: { "data-testid": "quarterly-declaration" }
    }) }}

    {{ govukButton({
      text: confirmAction,
      attributes: { "data-testid": "quarterly-confirm" }
    }) }}
  </form>
{% endblock %}

{% extends 'onboarding/_layout.njk' %}

{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% block stepBody %}
  <form method="post" action="{{ action }}" novalidate data-testid="onboarding-form">
    {{ govukCheckboxes({
      idPrefix: "batteryTypes",
      name: "batteryTypes",
      errorMessage: { text: errors[firstFlag] } if errors[firstFlag],
      items: categoryItems
    }) }}

    {{ govukInsetText({
      text: caveat,
      attributes: { "data-testid": "battery-categories-caveat" }
    }) }}

    {{ govukButton({
      text: labels.continueAction,
      attributes: { "data-testid": "onboarding-continue" }
    }) }}
  </form>
{% endblock %}

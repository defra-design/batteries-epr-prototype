{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ heading }}</h1>
      <p class="govuk-body-l">{{ intro }}</p>
      <p class="govuk-body" data-testid="home-prototype-banner">{{ prototypeBanner }}</p>
    </div>
  </div>

  <div class="govuk-grid-row app-task-cards" data-testid="home-journeys">
    <div class="govuk-grid-column-one-half">
      <div class="govuk-summary-card" data-testid="home-journey-producer">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">{{ journeys.producer.title }}</h2>
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ journeys.producer.description }}</p>
          <ul class="govuk-list govuk-list--bullet">
            {% for item in journeys.producer.bullets %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {{ govukButton({
            text: journeys.producer.primaryAction,
            href: producerSignInUrl,
            isStartButton: true,
            attributes: { "data-testid": "home-journey-producer-cta" }
          }) }}
          <p class="govuk-body">
            <a class="govuk-link" href="{{ publicRegisterUrl }}" data-testid="home-public-register-cta">{{ journeys.producer.secondaryAction }}</a>
          </p>
        </div>
      </div>
    </div>

    <div class="govuk-grid-column-one-half">
      <div class="govuk-summary-card" data-testid="home-journey-compliance-scheme">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">{{ journeys.complianceScheme.title }}</h2>
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ journeys.complianceScheme.description }}</p>
          <ul class="govuk-list govuk-list--bullet">
            {% for item in journeys.complianceScheme.bullets %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {{ govukButton({
            text: journeys.complianceScheme.primaryAction,
            href: complianceSchemeSignInUrl,
            isStartButton: true,
            attributes: { "data-testid": "home-journey-compliance-scheme-cta" }
          }) }}
        </div>
      </div>
    </div>
  </div>

  <div class="govuk-grid-row app-task-cards" data-testid="home-journeys-row-2">
    <div class="govuk-grid-column-one-half">
      <div class="govuk-summary-card" data-testid="home-journey-operator">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">{{ journeys.operator.title }}</h2>
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ journeys.operator.description }}</p>
          <ul class="govuk-list govuk-list--bullet">
            {% for item in journeys.operator.bullets %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {{ govukButton({
            text: journeys.operator.primaryAction,
            href: operatorSignInUrl,
            isStartButton: true,
            attributes: { "data-testid": "home-journey-operator-cta" }
          }) }}
        </div>
      </div>
    </div>

    <div class="govuk-grid-column-one-half">
      <div class="govuk-summary-card" data-testid="home-journey-regulator">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">{{ journeys.regulator.title }}</h2>
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ journeys.regulator.description }}</p>
          <ul class="govuk-list govuk-list--bullet">
            {% for item in journeys.regulator.bullets %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {{ govukButton({
            text: journeys.regulator.primaryAction,
            href: regulatorSignInUrl,
            isStartButton: true,
            attributes: { "data-testid": "home-journey-regulator-cta" }
          }) }}
        </div>
      </div>
    </div>
  </div>

  {% if showNi %}
  <div class="govuk-grid-row" data-testid="home-journeys-row-3">
    <div class="govuk-grid-column-full">
      <div class="govuk-summary-card" data-testid="home-journey-ni">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">{{ niJourney.title }}</h2>
          <div class="app-task-cards__status">
            {{ govukTag({ text: "EUBR" }) }}
          </div>
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ niJourney.description }}</p>
          <ul class="govuk-list govuk-list--bullet">
            {% for item in niJourney.bullets %}
              <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {{ govukButton({
            text: niJourney.primaryAction,
            href: niSignInUrl,
            isStartButton: true,
            attributes: { "data-testid": "home-journey-ni-cta" }
          }) }}
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  {% if reference %}
  <div class="govuk-grid-row" data-testid="home-reference">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-m">{{ reference.heading }}</h2>
      <p class="govuk-body">{{ reference.description }}</p>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ npwdPackagingComparisonUrl }}" data-testid="home-npwd-comparison-link">{{ reference.npwdComparisonLinkText }}</a>
      </p>
    </div>
  </div>
  {% endif %}
{% endblock %}

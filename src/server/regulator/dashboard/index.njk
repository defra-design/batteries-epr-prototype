{% extends 'layouts/page.njk' %}

{% from "heading/macro.njk" import appHeading %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ appHeading({ text: heading.text, organisationName: heading.caption }) }}
      <p class="govuk-body" data-testid="regulator-intro">{{ introParagraph }}</p>
      <p class="govuk-body">
        <strong>Compliance period:</strong> <span data-testid="regulator-period">{{ pagePayload.compliancePeriodYear }}</span>
      </p>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ regulatorSignInUrl }}" data-testid="regulator-switch">{{ switchAgencyAction }}</a>
      </p>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ regulatorTargetsUrl }}" data-testid="regulator-targets-link">{{ targetsAction }}</a>
      </p>
    </div>
  </div>

  <div id="regulator-dashboard" data-testid="regulator-dashboard">
    <div class="govuk-grid-row govuk-!-margin-top-4" data-testid="regulator-cards-row-1">
      <div class="govuk-grid-column-one-half">
        <div class="govuk-summary-card govuk-!-margin-bottom-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title" data-testid="tile-schemes-title">Compliance schemes</h2>
          </div>
          <div class="govuk-summary-card__content">
            <p class="govuk-body" data-testid="tile-schemes-count"></p>
            <p class="govuk-body" data-testid="tile-schemes-action"></p>
          </div>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <div class="govuk-summary-card govuk-!-margin-bottom-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title" data-testid="tile-operators-title">Operators (ABTO/ABE)</h2>
          </div>
          <div class="govuk-summary-card__content">
            <p class="govuk-body" data-testid="tile-operators-count"></p>
            <p class="govuk-body" data-testid="tile-operators-action"></p>
          </div>
        </div>
      </div>
    </div>

    <div class="govuk-grid-row" data-testid="regulator-cards-row-2">
      <div class="govuk-grid-column-one-half">
        <div class="govuk-summary-card govuk-!-margin-bottom-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title" data-testid="tile-producers-title">Registered producers</h2>
          </div>
          <div class="govuk-summary-card__content">
            <p class="govuk-body" data-testid="tile-producers-count"></p>
            <p class="govuk-body" data-testid="tile-producers-action"></p>
          </div>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <div class="govuk-summary-card govuk-!-margin-bottom-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title" data-testid="tile-evidence-title">Evidence notes</h2>
          </div>
          <div class="govuk-summary-card__content">
            <p class="govuk-body" data-testid="tile-evidence-count"></p>
            <p class="govuk-body" data-testid="tile-evidence-action"></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('regulatorDashboard.js') }}"></script>
{% endblock %}

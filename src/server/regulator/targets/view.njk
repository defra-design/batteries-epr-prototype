{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if saved %}
        {{ govukNotificationBanner({
          type: "success",
          text: labels.savedMessage,
          attributes: { "data-testid": "regulator-targets-saved" }
        }) }}
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="regulator-targets-heading">{{ heading }}</h1>
      <p class="govuk-body" data-testid="regulator-targets-agency" hidden></p>
      <p class="govuk-body">{{ intro }}</p>

      {{ govukInsetText({
        text: caveat,
        attributes: { "data-testid": "battery-categories-caveat" }
      }) }}

      <form method="post" novalidate data-testid="regulator-targets-form">
        <h2 class="govuk-heading-m">{{ labels.collectionHeading }}</h2>
        <p class="govuk-hint">{{ labels.collectionHint }}</p>
        <div data-testid="regulator-targets-collection-fields"></div>

        <h2 class="govuk-heading-m">{{ labels.recyclingHeading }}</h2>
        <p class="govuk-hint">{{ labels.recyclingHint }}</p>
        <div data-testid="regulator-targets-recycling-fields"></div>

        {{ govukDetails({
          summaryText: labels.explanationSummary,
          html: labels.explanationHtml,
          attributes: { "data-testid": "regulator-targets-explanation" }
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: labels.saveAction,
            type: "submit",
            attributes: { "data-testid": "regulator-targets-save" }
          }) }}
          <a class="govuk-link" href="{{ dashboardUrl }}" data-testid="regulator-targets-cancel">{{ labels.backToDashboardAction }}</a>
        </div>
      </form>

      <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ labels.historyPreviewHeading }}</h2>
      <ol class="govuk-list" data-testid="regulator-targets-history"></ol>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ auditTrailUrl }}" data-testid="regulator-targets-history-link">{{ labels.historyViewAllAction }}</a>
      </p>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('regulatorTargets.js') }}"></script>
{% endblock %}

{% extends 'layouts/page.njk' %}

{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="audit-trail-heading">{{ heading }}</h1>
      <p class="govuk-body" data-testid="audit-trail-agency" hidden></p>
      <p class="govuk-body">{{ intro }}</p>

      {{ govukWarningText({
        text: labels.warningText,
        iconFallbackText: "Warning",
        attributes: { "data-testid": "audit-trail-warning" }
      }) }}

      <table class="govuk-table" data-testid="audit-trail-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ labels.columns.date }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.target }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.previous }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ labels.columns.new }}</th>
            <th scope="col" class="govuk-table__header">{{ labels.columns.changedBy }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body" data-testid="audit-trail-list"></tbody>
      </table>
      <p class="govuk-body" data-testid="audit-trail-empty" hidden>{{ labels.empty }}</p>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ dashboardUrl }}" data-testid="audit-trail-back">{{ labels.backToDashboardAction }}</a>
      </p>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('regulatorAuditTrail.js') }}"></script>
{% endblock %}

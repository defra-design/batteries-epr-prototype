{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if saved %}
        {{ govukNotificationBanner({
          type: "success",
          text: labels.savedMessage,
          attributes: { "data-testid": "regulator-categories-saved" }
        }) }}
      {% endif %}

      <h1 class="govuk-heading-l" data-testid="regulator-categories-heading">{{ heading }}</h1>
      <p class="govuk-body" data-testid="regulator-categories-agency" hidden></p>
      <p class="govuk-body">{{ intro }}</p>

      {{ govukInsetText({
        text: caveat,
        attributes: { "data-testid": "battery-categories-caveat" }
      }) }}

      <form method="post" novalidate data-testid="regulator-categories-form">
        <h2 class="govuk-heading-m">{{ labels.rowsHeading }}</h2>
        <p class="govuk-hint">{{ labels.rowsHint }}</p>

        <div id="category-rows" data-testid="regulator-categories-rows"></div>

        {{ govukButton({
          text: labels.addAction,
          type: "button",
          classes: "govuk-button--secondary",
          attributes: { "data-testid": "regulator-categories-add" }
        }) }}

        <input type="hidden" name="categoriesJson" id="categoriesJson" data-testid="regulator-categories-json" />

        <div class="govuk-button-group">
          {{ govukButton({
            text: labels.saveAction,
            type: "submit",
            attributes: { "data-testid": "regulator-categories-save" }
          }) }}
          <a class="govuk-link" href="{{ dashboardUrl }}" data-testid="regulator-categories-cancel">{{ labels.backToDashboardAction }}</a>
        </div>
      </form>

      <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ labels.historyPreviewHeading }}</h2>
      <ol class="govuk-list" data-testid="regulator-categories-history"></ol>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ auditTrailUrl }}" data-testid="regulator-categories-history-link">{{ labels.historyViewAllAction }}</a>
      </p>
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('regulatorCategories.js') }}"></script>
{% endblock %}

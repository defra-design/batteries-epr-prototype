{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">{{ body }}</p>

      <div data-testid="dev-data" data-dev-data-root></div>
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('devData.js') }}"></script>
{% endblock %}

{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l" data-testid="scheme-represented-heading">{{ heading }}</h1>
      <p class="govuk-body" data-testid="scheme-represented-intro">{{ labels.intro }}</p>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.schemeNameLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="scheme-represented-scheme-name">—</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.periodLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="scheme-represented-period">—</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ labels.rosterLabel }}</dt>
          <dd class="govuk-summary-list__value" data-testid="scheme-represented-roster">{{ labels.rosterPending }}</dd>
        </div>
      </dl>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ accountSchemeUrl }}" data-testid="scheme-represented-view-scheme">{{ labels.viewSchemeAction }}</a>
      </p>

      {{ govukButton({
        text: labels.backToDashboardAction,
        href: dashboardUrl,
        attributes: { "data-testid": "scheme-represented-back" }
      }) }}
    </div>
  </div>

  <script type="application/json" id="page-payload" data-testid="page-payload">{{ pagePayload | dump | safe }}</script>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('annualReturnSchemeRepresented.js') }}"></script>
{% endblock %}

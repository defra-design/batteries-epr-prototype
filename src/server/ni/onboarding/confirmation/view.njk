{% extends 'ni/_layout.njk' %}

{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "eubr-annotation/macro.njk" import eubrAnnotation %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% call eubrAnnotation('registration') %}
        {{ govukPanel({
          titleText: labels.panelTitle,
          html: labels.panelBody + "<br><strong data-testid=\"ni-bprn\">" + bprn + "</strong>"
        }) }}
      {% endcall %}

      {{ govukSummaryList({
        rows: [
          { key: { text: labels.statusLabel }, value: { text: labels.statusValue } },
          { key: { text: labels.regulatorLabel }, value: { text: labels.regulatorValue } }
        ]
      }) }}

      <h2 class="govuk-heading-m">{{ labels.nextHeading }}</h2>
      <p class="govuk-body">{{ labels.nextBody }}</p>

      {{ govukButton({
        text: labels.continueAction,
        href: dashboardUrl,
        attributes: { "data-testid": "ni-confirmation-continue" }
      }) }}
    </div>
  </div>
{% endblock %}

{% extends 'ni/_layout.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>

      <div data-testid="ni-product-requirements">
        <p class="govuk-body" data-ni-requirements-empty>{{ empty }}</p>
        <div data-ni-requirements-results hidden></div>
      </div>

      {{ govukButton({
        text: "Back to your dashboard",
        href: dashboardUrl,
        classes: "govuk-button--secondary",
        attributes: { "data-testid": "ni-product-requirements-back" }
      }) }}
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ getAssetPath('niProductRequirements.js') }}"></script>
  {{ super() }}
{% endblock %}

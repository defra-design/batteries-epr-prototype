{% extends 'ni/_layout.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "eubr-annotation/macro.njk" import eubrAnnotation %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>

      {% call eubrAnnotation('collectionTargets') %}
        {{ govukInsetText({ text: note, attributes: { "data-testid": "ni-obligation-note" } }) }}
      {% endcall %}

      {% call eubrAnnotation('collectionTargets') %}
        <div data-testid="ni-obligation">
          <p class="govuk-body" data-ni-obligation-empty>{{ empty }}</p>
          <div data-ni-obligation-results hidden></div>
        </div>
      {% endcall %}

      {{ govukButton({
        text: "Back to your dashboard",
        href: dashboardUrl,
        classes: "govuk-button--secondary",
        attributes: { "data-testid": "ni-obligation-back" }
      }) }}
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('niObligation.js') }}"></script>
{% endblock %}

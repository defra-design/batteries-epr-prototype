{% extends 'ni/_layout.njk' %}

{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "eubr-annotation/macro.njk" import eubrAnnotation %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ heading }}</h1>
      <p class="govuk-body">{{ intro }}</p>
      {{ govukButton({
        text: "Start registration",
        href: startUrl,
        attributes: { "data-testid": "ni-start-registration" }
      }) }}
    </div>
  </div>

  <div class="govuk-grid-row" data-testid="ni-registration-status">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body" data-ni-registration-status>No registration submitted yet.</p>
    </div>
  </div>

  <div class="govuk-grid-row" data-testid="ni-annual-returns">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-m">Annual returns</h2>
      <p class="govuk-body" data-ni-annual-returns-empty>No annual returns submitted yet.</p>
      <table class="govuk-table" data-ni-annual-returns-table hidden>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Compliance period</th>
            <th scope="col" class="govuk-table__header">Reference</th>
            <th scope="col" class="govuk-table__header">Submitted</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body" data-ni-annual-returns-body></tbody>
      </table>
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-4" data-testid="ni-dashboard-cards" data-ni-current-period="{{ currentPeriod }}">
    {% for card in cards %}
      <div class="govuk-grid-column-{{ card.column }}">
        {% call eubrAnnotation(card.eubrKey) %}
          <div class="govuk-summary-card govuk-!-margin-bottom-4">
            <div class="govuk-summary-card__title-wrapper">
              <div>
                <h2 class="govuk-summary-card__title" data-testid="ni-card-{{ card.eubrKey }}-title">
                  {{ card.title }}
                </h2>
                <p class="govuk-body-s govuk-!-margin-bottom-0">{{ card.description }}</p>
              </div>
              <div class="app-task-cards__status" data-ni-card-status="{{ card.eubrKey }}">
                {{ govukTag({ text: card.status.text, classes: card.status.classes }) }}
              </div>
            </div>
            <div class="govuk-summary-card__content">
              <p class="govuk-body">{{ card.body }}</p>
              {% if cardLinks[card.eubrKey] %}
                <p class="govuk-body">
                  <a class="govuk-link" href="{{ cardLinks[card.eubrKey].href }}" data-testid="ni-card-{{ card.eubrKey }}-link">{{ cardLinks[card.eubrKey].text }}</a>
                </p>
              {% endif %}
            </div>
          </div>
        {% endcall %}
      </div>
    {% endfor %}
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('niDashboard.js') }}"></script>
{% endblock %}
